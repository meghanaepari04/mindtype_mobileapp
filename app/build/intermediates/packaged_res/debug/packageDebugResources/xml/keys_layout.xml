<?xml version="1.0" encoding="utf-8"?>
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="10%p"
    android:horizontalGap="0px"
    android:verticalGap="0px"
    android:keyHeight="56dp">

    <!-- Row 1: q w e r t y u i o p -->
    <Row>
        <Key android:codes="113" android:keyLabel="q" android:keyEdgeFlags="left" />
        <Key android:codes="119" android:keyLabel="w" />
        <Key android:codes="101" android:keyLabel="e" />
        <Key android:codes="114" android:keyLabel="r" />
        <Key android:codes="116" android:keyLabel="t" />
        <Key android:codes="121" android:keyLabel="y" />
        <Key android:codes="117" android:keyLabel="u" />
        <Key android:codes="105" android:keyLabel="i" />
        <Key android:codes="111" android:keyLabel="o" />
        <Key android:codes="112" android:keyLabel="p" android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 2: a s d f g h j k l -->
    <Row>
        <Key android:codes="97"  android:keyLabel="a" android:keyEdgeFlags="left"
             android:keyWidth="10%p" android:horizontalGap="5%p" />
        <Key android:codes="115" android:keyLabel="s" android:keyWidth="10%p" />
        <Key android:codes="100" android:keyLabel="d" android:keyWidth="10%p" />
        <Key android:codes="102" android:keyLabel="f" android:keyWidth="10%p" />
        <Key android:codes="103" android:keyLabel="g" android:keyWidth="10%p" />
        <Key android:codes="104" android:keyLabel="h" android:keyWidth="10%p" />
        <Key android:codes="106" android:keyLabel="j" android:keyWidth="10%p" />
        <Key android:codes="107" android:keyLabel="k" android:keyWidth="10%p" />
        <Key android:codes="108" android:keyLabel="l" android:keyEdgeFlags="right"
             android:keyWidth="10%p" />
    </Row>

    <!-- Row 3: Shift + z x c v b n m + Backspace -->
    <Row>
        <Key android:codes="-1"  android:keyLabel="⇧" android:keyEdgeFlags="left"
             android:keyWidth="15%p" android:isModifier="true" android:isSticky="true" />
        <Key android:codes="122" android:keyLabel="z" android:keyWidth="10%p" />
        <Key android:codes="120" android:keyLabel="x" android:keyWidth="10%p" />
        <Key android:codes="99"  android:keyLabel="c" android:keyWidth="10%p" />
        <Key android:codes="118" android:keyLabel="v" android:keyWidth="10%p" />
        <Key android:codes="98"  android:keyLabel="b" android:keyWidth="10%p" />
        <Key android:codes="110" android:keyLabel="n" android:keyWidth="10%p" />
        <Key android:codes="109" android:keyLabel="m" android:keyWidth="10%p" />
        <Key android:codes="-5"  android:keyLabel="⌫" android:isRepeatable="true"
             android:keyWidth="15%p" android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 4: ?123 | Emoji | Space | . | ↵ -->
    <Row android:rowEdgeFlags="bottom">
        <Key android:codes="-2"  android:keyLabel="123"  android:keyEdgeFlags="left"
             android:keyWidth="15%p" />
        <Key android:codes="-12" android:keyLabel="🙂"  android:keyWidth="15%p" />
        <Key android:codes="32"  android:keyLabel="space" android:keyWidth="40%p" />
        <Key android:codes="46"  android:keyLabel="."  android:keyWidth="15%p" />
        <Key android:codes="-4"  android:keyLabel="↵"    android:keyEdgeFlags="right"
             android:keyWidth="15%p" />
    </Row>

</Keyboard>
